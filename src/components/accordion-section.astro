---
import Accordion from "./ui/accordion.astro";
import AccordionItem from "./ui/accordion-item.astro";
import AccordionContent from "./ui/accordion-content.astro";
import AccordionHeader from "./accordion-header.astro";
import Link from "./link.astro";
import { Image } from "astro:assets";

// Import the specific images used in this component
import officeImage from "../assets/images/1/DSCF1597.jpg";
import presentationImage from "../assets/images/1/DSCF1647.jpg";
import ethanImage from "../assets/images/1/DSCF1088.jpg";

const LOCATION_URL = "https://maps.app.goo.gl/6TgEU4BhV6quZCf49";
const LUMA_URL = "https://luma.com/fpgrzjc5";
---

<Accordion className="flex flex-col gap-8">
  <AccordionItem>
    <AccordionHeader>When is it?</AccordionHeader>
    <AccordionContent>
      Demo Night 3 is on <span class="font-bold">February 28th</span> at{" "}
      <span class="font-bold">6:00 PM</span> at the{" "}
      <Link href={LOCATION_URL}>CoLab office</Link>.
    </AccordionContent>
  </AccordionItem>
  <AccordionItem>
    <AccordionHeader> How can I sign up to present / attend? </AccordionHeader>
    <AccordionContent>
      Registration for the next event is <Link href={LUMA_URL}>here</Link>. No
      matter if you're presenting or only coming to watch, we encourage you to
      register so we can get an accurate headcount.
    </AccordionContent>
  </AccordionItem>
  <Image
    src={officeImage}
    alt="Photo of the Spellbook office"
    class="rounded-base w-full"
    width={1200}
    quality={85}
    format="webp"
  />
  <AccordionItem>
    <AccordionHeader>What are the vibes like?</AccordionHeader>
    <AccordionContent>
      See more pictures in our
      <a href="/demo-night/gallery" class="font-bold underline cursor-pointer"
        >gallery</a
      >
      of past events! 📸
    </AccordionContent>
  </AccordionItem>
  <Image
    src={presentationImage}
    alt="Photo of a presentation at Demo Night"
    class="rounded-base w-full"
    width={1200}
    quality={85}
    format="webp"
  />
  <AccordionItem>
    <AccordionHeader>What are the rules?</AccordionHeader>
    <AccordionContent>
      <ul class="list-disc pl-4 space-y-2">
        <li>
          You can present about anything you want, as long as it's technical in
          nature, and you built or created it in some way.
        </li>
        <li>
          Presentations should be about 5-10 minutes long. We're limiting the
          time to keep the event moving along and allow more people to present.
        </li>
        <li>
          Other than that, it can be anything you want – from functional
          programming, a neat AI tool you've been using, or about an
          <code class="italic">[insert niche topic here]</code> that you're really
          interested in.
        </li>
      </ul>
    </AccordionContent>
  </AccordionItem>
  <Image
    src={ethanImage}
    alt="Photo of Ethan Denny"
    class="rounded-base w-full"
    width={1200}
    quality={85}
    format="webp"
  />
  <AccordionItem>
    <AccordionHeader>Who's organizing it?</AccordionHeader>
    <AccordionContent>
      Demo Night is brought to you by
      <Link href="https://ethandenny.dev">Ethan Denny</Link> and
      <Link href="https://jackharrhy.dev">Jack Harrhy</Link>, with our hosting
      spaces provided by the fine folks at <Link href="https://spellbook.com"
        >Spellbook</Link
      > and <Link href="https://www.colabsoftware.com/">CoLab</Link>. Gallery
      photos taken by <Link href="https://www.instagram.com/thecrypticcanadian/"
        >Ethan Crann</Link
      > and <Link href="https://jack.camera">Jack</Link>.
    </AccordionContent>
  </AccordionItem>
</Accordion>
